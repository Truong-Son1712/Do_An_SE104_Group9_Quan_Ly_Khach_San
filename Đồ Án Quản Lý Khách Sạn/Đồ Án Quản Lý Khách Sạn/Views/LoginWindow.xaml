<Window x:Class="Đồ_Án_Quản_Lý_Khách_Sạn.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Đồ_Án_Quản_Lý_Khách_Sạn.ViewModels"
        xmlns:conv="clr-namespace:Đồ_Án_Quản_Lý_Khách_Sạn.Helpers"
        Title="Đăng Nhập – Hệ Thống Quản Lý Khách Sạn"
        Height="560" Width="880"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <Border CornerRadius="16" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL – blue gradient -->
            <Border Grid.Column="0" CornerRadius="16,0,0,16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A237E" Offset="0"/>
                        <GradientStop Color="#1565C0" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="30">
                        <!-- Hotel Icon -->
                        <Border Width="80" Height="80" CornerRadius="40"
                                Background="#20FFFFFF" Margin="0,0,0,20"
                                HorizontalAlignment="Center">
                            <TextBlock Text="🏨" FontSize="40"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="KHÁCH SẠN"
                                   FontSize="22" FontWeight="Black"
                                   Foreground="White" TextAlignment="Center"/>
                        <TextBlock Text="GRAND HOTEL"
                                   FontSize="13" FontWeight="Light"
                                   Foreground="#90CAF9" TextAlignment="Center"
                                   Margin="0,4,0,32"/>

                        <Border Width="50" Height="2" Background="#30FFFFFF"
                                HorizontalAlignment="Center" Margin="0,0,0,32"/>

                        <StackPanel>
                            <TextBlock Text="TÍNH NĂNG HỆ THỐNG"
                                       Foreground="#64B5F6" FontSize="10" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,14"/>

                            <Border Background="#18FFFFFF" CornerRadius="10" Padding="12,9" Margin="0,0,0,7">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="32" Height="32" CornerRadius="16" Background="#2281C784">
                                        <TextBlock Text="🛏️" FontSize="16"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Quản lý phòng &amp; đặt phòng"
                                               Foreground="White" FontSize="13"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#18FFFFFF" CornerRadius="10" Padding="12,9" Margin="0,0,0,7">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="32" Height="32" CornerRadius="16" Background="#221565C0">
                                        <TextBlock Text="👤" FontSize="16"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Quản lý khách hàng"
                                               Foreground="White" FontSize="13"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#18FFFFFF" CornerRadius="10" Padding="12,9" Margin="0,0,0,7">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="32" Height="32" CornerRadius="16" Background="#22FF8F00">
                                        <TextBlock Text="💳" FontSize="16"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Hóa đơn &amp; thanh toán"
                                               Foreground="White" FontSize="13"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#18FFFFFF" CornerRadius="10" Padding="12,9">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="32" Height="32" CornerRadius="16" Background="#22AB47BC">
                                        <TextBlock Text="📊" FontSize="16"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Báo cáo doanh thu"
                                               Foreground="White" FontSize="13"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="SE104 – Nhóm 9"
                               Foreground="#5C6BC0" FontSize="11"
                               HorizontalAlignment="Center" VerticalAlignment="Bottom"
                               Margin="0,0,0,16"/>
                </Grid>
            </Border>

            <!-- RIGHT PANEL – login form -->
            <Border Grid.Column="1" Background="White" CornerRadius="0,16,16,0">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Margin="48,0">
                        <TextBlock Text="Chào mừng trở lại!"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="#1A237E" Margin="0,0,0,6"/>
                        <TextBlock Text="Đăng nhập để tiếp tục"
                                   FontSize="13" Foreground="#78909C"
                                   Margin="0,0,0,36"/>

                        <!-- Tài khoản -->
                        <TextBlock Text="TÀI KHOẢN" Style="{StaticResource Label}"
                                   Foreground="#546E7A"/>
                        <TextBox x:Name="TxtTaiKhoan"
                                 Text="{Binding TaiKhoan, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,18"
                                 KeyDown="Input_KeyDown"/>

                        <!-- Mật khẩu -->
                        <TextBlock Text="MẬT KHẨU" Style="{StaticResource Label}"
                                   Foreground="#546E7A"/>
                        <PasswordBox x:Name="PbMatKhau"
                                     Margin="0,0,0,8"
                                     KeyDown="Input_KeyDown"/>

                        <!-- Lỗi -->
                        <Border Background="#FFEBEE" CornerRadius="6" Padding="12,8"
                                Margin="0,0,0,16"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource BoolVis}}">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#C62828" FontSize="12" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Đăng nhập -->
                        <Button Content="ĐĂNG NHẬP"
                                Style="{StaticResource BtnPrimary}"
                                Height="44" FontSize="14"
                                Click="BtnLogin_Click"
                                Margin="0,0,0,20"/>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- Drag region -->
            <Rectangle Grid.ColumnSpan="2" VerticalAlignment="Top" Height="40"
                        Fill="Transparent" MouseLeftButtonDown="Window_MouseDown"/>

            <!-- Close button – Panel.ZIndex ensures it stays above the drag Rectangle -->
            <Button Grid.Column="1" Panel.ZIndex="10"
                    Content="✕" Width="32" Height="32"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,12,12,0"
                    Background="Transparent" BorderThickness="0"
                    FontSize="14" Foreground="#90A4AE"
                    Cursor="Hand"
                    Click="BtnClose_Click"/>
        </Grid>
    </Border>
</Window>
