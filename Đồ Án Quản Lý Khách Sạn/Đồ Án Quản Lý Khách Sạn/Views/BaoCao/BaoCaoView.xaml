<UserControl x:Class="Đồ_Án_Quản_Lý_Khách_Sạn.Views.BaoCao.BaoCaoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Đồ_Án_Quản_Lý_Khách_Sạn.Helpers"
             Background="{StaticResource BgBrush}">
    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="Currency"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- Header -->
            <StackPanel Margin="0,0,0,20">
                <DockPanel Margin="0,0,0,4">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Năm:" VerticalAlignment="Center" FontWeight="SemiBold"
                                   FontSize="16" Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="24,0,8,0"/>
                        <ComboBox Width="110" ItemsSource="{Binding DanhSachNam}"
                                  SelectedItem="{Binding SelectedYear}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Style="{StaticResource H1}" Text="Báo Cáo Doanh Thu"
                               VerticalAlignment="Center"/>
                </DockPanel>
                <TextBlock Style="{StaticResource Body}" Text="Thống kê theo năm"/>
            </StackPanel>

            <!-- Summary cards -->
            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,20">
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1565C0" Offset="0"/>
                            <GradientStop Color="#1E88E5" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="💰" FontSize="24" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TongDoanhThuNam, Converter={StaticResource Currency}}"
                                   FontSize="18" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                        <TextBlock Text="Tổng Doanh Thu Năm" Foreground="#BBDEFB" FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2E7D32" Offset="0"/>
                            <GradientStop Color="#43A047" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="🧾" FontSize="24" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TongHoaDon}" FontSize="34" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Tổng Hóa Đơn" Foreground="#C8E6C9" FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#E65100" Offset="0"/>
                            <GradientStop Color="#FF8F00" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="👥" FontSize="24" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TongLuotKhach}" FontSize="34" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Lượt Khách" Foreground="#FFE0B2" FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6A1B9A" Offset="0"/>
                            <GradientStop Color="#AB47BC" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="📊" FontSize="24" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding CongSuatPhong, StringFormat='{}{0:F1}%'}"
                                   FontSize="34" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Công Suất Phòng" Foreground="#E1BEE7" FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Two columns: Monthly chart + Room type report -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <!-- Doanh thu theo tháng (bar chart visual) -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Doanh Thu Theo Tháng" Style="{StaticResource H3}" Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding DoanhThuTheoThang}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="44"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Thang}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11" VerticalAlignment="Center"/>
                                        <ProgressBar Grid.Column="1" Margin="6,0"
                                                     Value="{Binding TyLe, Mode=OneWay}" Maximum="100"
                                                     Height="16"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DoanhThu, Converter={StaticResource Currency}}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding SoHoaDon, StringFormat='({0})'}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Thống kê nút -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Nút Theo Loại Phòng -->
                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16">
                        <Button Click="BtnThongKeLoaiPhong_Click" Background="Transparent"
                                BorderThickness="0" Cursor="Hand" Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1565C0" Offset="0"/>
                                            <GradientStop Color="#1E88E5" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="🏷️" FontSize="20"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <TextBlock Text="Theo Loại Phòng" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#1A237E"/>
                                    <TextBlock Text="Doanh thu phân theo loại phòng" FontSize="11"
                                               Foreground="#90A4AE" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="›" FontSize="20" Foreground="#BDBDBD"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                            </Grid>
                        </Button>
                    </Border>

                    <!-- Nút Theo Phòng -->
                    <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
                        <Button Click="BtnThongKePhong_Click" Background="Transparent"
                                BorderThickness="0" Cursor="Hand" Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#6A1B9A" Offset="0"/>
                                            <GradientStop Color="#AB47BC" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="📊" FontSize="20"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <TextBlock Text="Theo Phòng" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#1A237E"/>
                                    <TextBlock Text="Doanh thu từng phòng riêng lẻ" FontSize="11"
                                               Foreground="#90A4AE" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="›" FontSize="20" Foreground="#BDBDBD"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                            </Grid>
                        </Button>
                    </Border>

                    <!-- Loại khách -->
                    <Border Grid.Row="2" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Phân Loại Khách" Style="{StaticResource H3}" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#E3F2FD" CornerRadius="8" Padding="12" Margin="0,0,6,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="🇻🇳" FontSize="24" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding LoaiKhachNoiDia}"
                                                   FontSize="16" FontWeight="Bold" Foreground="#1565C0"
                                                   HorizontalAlignment="Center" Margin="0,4,0,2"/>
                                        <TextBlock Text="Nội Địa" Foreground="#1976D2" FontSize="11"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#FFF3E0" CornerRadius="8" Padding="12" Margin="6,0,0,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="🌍" FontSize="24" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding LoaiKhachNuocNgoai}"
                                                   FontSize="16" FontWeight="Bold" Foreground="#E65100"
                                                   HorizontalAlignment="Center" Margin="0,4,0,2"/>
                                        <TextBlock Text="Nước Ngoài" Foreground="#EF6C00" FontSize="11"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
