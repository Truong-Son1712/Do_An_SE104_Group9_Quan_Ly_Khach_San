<Window x:Class="Đồ_Án_Quản_Lý_Khách_Sạn.Views.NhanVien.NhanVienDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông Tin Nhân Viên" Height="500" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">

    <Border CornerRadius="12" ClipToBounds="True" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="12,12,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1565C0" Offset="0"/>
                        <GradientStop Color="#1E88E5" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,0,8,0">
                    <TextBlock x:Name="TxtTitle" Text="Thêm Nhân Viên"
                               Foreground="White" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Button Style="{StaticResource BtnClose}" Content="✕"
                            Click="BtnCancel_Click" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" Margin="24,16">
                <StackPanel>
                    <StackPanel>
                        <TextBlock Text="Họ và Tên *" Style="{StaticResource Label}"/>
                        <TextBox x:Name="TxtHoTen"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tài Khoản *" Style="{StaticResource Label}"/>
                            <TextBox x:Name="TxtTaiKhoan"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Vai Trò *" Style="{StaticResource Label}"/>
                            <ComboBox x:Name="CboVaiTro">
                                <ComboBoxItem Content="Lễ Tân"        Tag="LeTan"  IsSelected="True"/>
                                <ComboBoxItem Content="Quản Lý"       Tag="QuanLy"/>
                                <ComboBoxItem Content="Quản Trị Viên" Tag="Admin"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Mật khẩu (chỉ hiển thị khi thêm mới) -->
                    <Grid x:Name="PnlMatKhau">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Mật Khẩu *" Style="{StaticResource Label}"/>
                            <PasswordBox x:Name="PbMatKhau"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Xác Nhận *" Style="{StaticResource Label}"/>
                            <PasswordBox x:Name="PbXacNhan"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Email" Style="{StaticResource Label}"/>
                            <TextBox x:Name="TxtEmail"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Số Điện Thoại" Style="{StaticResource Label}"/>
                            <TextBox x:Name="TxtSDT"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel>
                        <TextBlock Text="Địa Chỉ" Style="{StaticResource Label}"/>
                        <TextBox x:Name="TxtDiaChi"/>
                    </StackPanel>

                    <Border x:Name="PnlError" Background="#FFEBEE" CornerRadius="6"
                            Padding="12,8" Visibility="Collapsed">
                        <TextBlock x:Name="TxtError" Foreground="#C62828" FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#F8FAFD" BorderBrush="#E0E0E0"
                    BorderThickness="0,1,0,0" CornerRadius="0,0,12,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Margin="24,0" VerticalAlignment="Center">
                    <Button Content="Hủy" Style="{StaticResource BtnOutline}" Width="90" Click="BtnCancel_Click" Margin="0,0,8,0"/>
                    <Button Content="💾  Lưu" Style="{StaticResource BtnPrimary}" Width="110" Click="BtnSave_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
