<Window x:Class="Đồ_Án_Quản_Lý_Khách_Sạn.Views.NhanVien.DoiMatKhauDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đổi Mật Khẩu" Height="460" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">

    <Border CornerRadius="12" ClipToBounds="True" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="12,12,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#E65100" Offset="0"/>
                        <GradientStop Color="#FF8F00" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,0,8,0">
                    <TextBlock Text="🔑  Đổi Mật Khẩu"
                               Foreground="White" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Button Style="{StaticResource BtnClose}" Content="✕" Foreground="#FFCC80"
                            Click="BtnCancel_Click" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="24,16">

                <!-- Thông tin nhân viên -->
                <Border Background="#FFF8E1" CornerRadius="8" Padding="12,10" Margin="0,0,0,16"
                        BorderBrush="#FFE082" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="38" Height="38" CornerRadius="19"
                                Background="#FF8F00" Margin="0,0,12,0" VerticalAlignment="Center">
                            <TextBlock Text="👤" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TxtHoTen"
                                       FontSize="14" FontWeight="SemiBold" Foreground="#1A237E"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                <TextBlock x:Name="TxtTaiKhoan" FontSize="12" Foreground="#546E7A"/>
                                <TextBlock Text=" · " FontSize="12" Foreground="#90A4AE"/>
                                <TextBlock x:Name="TxtVaiTro" FontSize="12" Foreground="#546E7A"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel x:Name="PnlCu">
                    <TextBlock Text="Mật Khẩu Hiện Tại *" Style="{StaticResource Label}"/>
                    <PasswordBox x:Name="PbCu"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Mật Khẩu Mới *" Style="{StaticResource Label}"/>
                    <PasswordBox x:Name="PbMoi"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Xác Nhận Mật Khẩu Mới *" Style="{StaticResource Label}"/>
                    <PasswordBox x:Name="PbXacNhan"/>
                </StackPanel>

                <Border x:Name="PnlError" Background="#FFEBEE" CornerRadius="6"
                        Padding="12,8" Visibility="Collapsed">
                    <TextBlock x:Name="TxtError" Foreground="#C62828" FontSize="12" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>

            <Border Grid.Row="2" Background="#F8FAFD" BorderBrush="#E0E0E0"
                    BorderThickness="0,1,0,0" CornerRadius="0,0,12,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Margin="24,0" VerticalAlignment="Center">
                    <Button Content="Hủy" Style="{StaticResource BtnOutline}" Width="90" Click="BtnCancel_Click" Margin="0,0,8,0"/>
                    <Button Content="✔  Lưu" Style="{StaticResource BtnWarning}" Width="110" Click="BtnSave_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
