<Window x:Class="Đồ_Án_Quản_Lý_Khách_Sạn.Views.Phong.DoiTrangThaiPhongDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Đồ_Án_Quản_Lý_Khách_Sạn.Helpers"
        Title="Đổi Trạng Thái Phòng" Height="340" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">
    <Window.Resources>
        <conv:TrangThaiPhongTextConverter  x:Key="TTText"/>
        <conv:TrangThaiPhongColorConverter x:Key="TTColor"/>
    </Window.Resources>

    <Border CornerRadius="12" ClipToBounds="True" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1565C0" Offset="0"/>
                        <GradientStop Color="#1E88E5" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,0,8,0">
                    <TextBlock Text="🔄  Cập Nhật Trạng Thái Phòng"
                               Foreground="White" FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Style="{StaticResource BtnClose}" Content="✕" Foreground="#90CAF9"
                            Click="BtnCancel_Click" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="24,20,24,12">

                <!-- Thông tin phòng -->
                <Border Background="#E3F2FD" CornerRadius="8" Padding="14,12" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="TxtSoPhong" FontSize="18" FontWeight="Bold"
                                       Foreground="#0D47A1"/>
                            <TextBlock x:Name="TxtLoaiPhong" FontSize="12" Foreground="#546E7A" Margin="0,2,0,0"/>
                        </StackPanel>
                        <!-- Trạng thái hiện tại -->
                        <Border Grid.Column="1" x:Name="BadgeCurrent" CornerRadius="12"
                                Padding="10,4" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtTrangThaiHienTai"
                                       Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Chọn trạng thái mới -->
                <TextBlock Text="Chọn trạng thái mới:" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                <ComboBox x:Name="CboTrangThai" Height="38" FontSize="13">
                    <ComboBoxItem Content="Trống (Sạch)" Tag="TrongSach"/>
                    <ComboBoxItem Content="Cần Dọn Dẹp" Tag="CanDonDep"/>
                    <ComboBoxItem Content="Bảo Dưỡng"   Tag="BaoDuong"/>
                </ComboBox>

            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F8FAFD" BorderBrush="#E0E0E0"
                    BorderThickness="0,1,0,0" CornerRadius="0,0,12,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Margin="24,0" VerticalAlignment="Center">
                    <Button Content="Hủy" Style="{StaticResource BtnOutline}" Width="90"
                            Click="BtnCancel_Click" Margin="0,0,8,0"/>
                    <Button Content="✔  Cập Nhật" Style="{StaticResource BtnPrimary}"
                            Width="130" Click="BtnConfirm_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
