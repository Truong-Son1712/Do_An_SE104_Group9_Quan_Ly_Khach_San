<Window x:Class="Đồ_Án_Quản_Lý_Khách_Sạn.Views.Phong.LoaiPhongDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loại Phòng" Height="400" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">

    <Border CornerRadius="12" ClipToBounds="True" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="12,12,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1565C0" Offset="0"/>
                        <GradientStop Color="#1E88E5" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,0,8,0">
                    <TextBlock x:Name="TxtTitle" Text="Thêm Loại Phòng"
                               Foreground="White" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Button Style="{StaticResource BtnClose}" Content="✕"
                            Click="BtnCancel_Click" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" Margin="24,16">
                <StackPanel>
                    <StackPanel>
                        <TextBlock Text="Tên Loại Phòng *" Style="{StaticResource Label}"/>
                        <TextBox x:Name="TxtTenLoaiPhong"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Giá / Đêm (₫) *" Style="{StaticResource Label}"/>
                            <TextBox x:Name="TxtGiaPhong"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Sức Chứa (người) *" Style="{StaticResource Label}"/>
                            <TextBox x:Name="TxtSucChua"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel>
                        <TextBlock Text="Mô Tả" Style="{StaticResource Label}"/>
                        <TextBox x:Name="TxtMoTa" Height="70" AcceptsReturn="True"
                                 VerticalContentAlignment="Top" Padding="10,8" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Border x:Name="PnlError" Background="#FFEBEE" CornerRadius="6"
                            Padding="12,8" Visibility="Collapsed">
                        <TextBlock x:Name="TxtError" Foreground="#C62828" FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#F8FAFD" BorderBrush="#E0E0E0"
                    BorderThickness="0,1,0,0" CornerRadius="0,0,12,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Margin="24,0" VerticalAlignment="Center">
                    <Button Content="Hủy" Style="{StaticResource BtnOutline}" Width="90" Click="BtnCancel_Click" Margin="0,0,8,0"/>
                    <Button Content="💾  Lưu" Style="{StaticResource BtnPrimary}" Width="110" Click="BtnSave_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
