<UserControl x:Class="Đồ_Án_Quản_Lý_Khách_Sạn.Views.Phong.LoaiPhongView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Đồ_Án_Quản_Lý_Khách_Sạn.Helpers"
             Background="{StaticResource BgBrush}">
    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="Currency"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource BtnPrimary}" Command="{Binding ThemCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Thêm Loại" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource BtnWarning}" Command="{Binding SuaCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✎" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Sửa" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource BtnDanger}" Command="{Binding XoaCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🗑" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Xóa" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel>
                <TextBlock Style="{StaticResource H1}" Text="Loại Phòng"/>
                <TextBlock Style="{StaticResource Body}" Text="Cấu hình các loại phòng và giá"/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding LoaiPhongs}" SelectedItem="{Binding Selected}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã"          Binding="{Binding MaLoaiPhong}"  Width="60"/>
                    <DataGridTextColumn Header="Tên Loại Phòng" Binding="{Binding TenLoaiPhong}" Width="*"/>
                    <DataGridTextColumn Header="Giá / Đêm"   Binding="{Binding GiaPhong, Converter={StaticResource Currency}}" Width="140"/>
                    <DataGridTextColumn Header="Sức Chứa"    Binding="{Binding SucChua, StringFormat='{}{0} người'}" Width="110"/>
                    <DataGridTextColumn Header="Mô Tả"       Binding="{Binding MoTa}"          Width="*"/>
                    <DataGridTextColumn Header="Số Phòng"    Binding="{Binding Phongs.Count}"   Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
