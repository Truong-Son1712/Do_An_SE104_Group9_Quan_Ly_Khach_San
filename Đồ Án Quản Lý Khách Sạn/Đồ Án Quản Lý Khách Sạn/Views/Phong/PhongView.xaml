<UserControl x:Class="Đồ_Án_Quản_Lý_Khách_Sạn.Views.Phong.PhongView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Đồ_Án_Quản_Lý_Khách_Sạn.Helpers"
             Background="{StaticResource BgBrush}">
    <UserControl.Resources>
        <conv:TrangThaiPhongTextConverter  x:Key="TTText"/>
        <conv:TrangThaiPhongColorConverter x:Key="TTColor"/>
        <conv:CurrencyConverter            x:Key="Currency"/>
        <conv:BoolToVisibilityConverter    x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource BtnPrimary}" Command="{Binding ThemCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Thêm Phòng" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource BtnWarning}" Command="{Binding SuaCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✎" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Sửa" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource BtnDanger}" Command="{Binding XoaCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🗑" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Xóa" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource BtnInfo}" Command="{Binding DoiTrangThaiCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Đổi Trạng Thái" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel>
                <TextBlock Style="{StaticResource H1}" Text="Quản Lý Phòng"/>
                <TextBlock Style="{StaticResource Body}" Text="Danh sách toàn bộ phòng khách sạn"/>
            </StackPanel>
        </DockPanel>

        <!-- Filters -->
        <Border Grid.Row="1" Style="{StaticResource CardSmall}" Margin="0,0,0,16">
            <WrapPanel>
                <StackPanel Width="220" Margin="0,0,16,0">
                    <TextBlock Text="Tìm kiếm" Style="{StaticResource Label}"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Số phòng, loại phòng…"/>
                </StackPanel>
                <StackPanel Width="180">
                    <TextBlock Text="Trạng thái" Style="{StaticResource Label}"/>
                    <ComboBox SelectedValue="{Binding FilterTrangThai}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="Tất cả" Tag="TatCa" IsSelected="True"/>
                        <ComboBoxItem Content="Trống (Sạch)"   Tag="TrongSach"/>
                        <ComboBoxItem Content="Đang Sử Dụng"  Tag="DangSuDung"/>
                        <ComboBoxItem Content="Cần Dọn Dẹp"   Tag="CanDonDep"/>
                        <ComboBoxItem Content="Bảo Dưỡng"     Tag="BaoDuong"/>
                        <ComboBoxItem Content="Đã Đặt"        Tag="DaDat"/>
                    </ComboBox>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Hệ số khách nước ngoài -->
        <Border Grid.Row="2" Style="{StaticResource CardSmall}" Margin="0,0,0,16"
                x:Name="PnlHeSo">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🌏" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="Hệ Số Giá Khách Nước Ngoài"
                                   FontWeight="SemiBold" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="TxtHeSoNote" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="Hệ số:" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                    <TextBox x:Name="TxtHeSo" Width="70" TextAlignment="Center"
                             FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center"
                             Height="34" Padding="6,0"/>
                    <TextBlock Text="x" VerticalAlignment="Center" FontSize="14"
                               FontWeight="Bold" Margin="6,0,12,0"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Button x:Name="BtnLuuHeSo" Content="💾  Lưu"
                            Style="{StaticResource BtnPrimary}" Height="34"
                            Padding="12,0" Click="BtnLuuHeSo_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Phongs}"
                      SelectedItem="{Binding SelectedPhong}"
                      Margin="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Số Phòng"   Binding="{Binding SoPhong}"              Width="100"/>
                    <DataGridTextColumn Header="Loại Phòng" Binding="{Binding LoaiPhong.TenLoaiPhong}" Width="*"/>
                    <DataGridTextColumn Header="Tầng"       Binding="{Binding Tang}"                  Width="70"/>
                    <DataGridTextColumn Header="Sức Chứa"   Binding="{Binding LoaiPhong.SucChua, StringFormat='{}{0} người'}" Width="100"/>
                    <DataGridTextColumn Header="Giá/Đêm"    Binding="{Binding LoaiPhong.GiaPhong, Converter={StaticResource Currency}}" Width="130"/>
                    <DataGridTemplateColumn Header="Trạng Thái" Width="160" SortMemberPath="TrangThai">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding TrangThai, Converter={StaticResource TTColor}}"
                                        CornerRadius="12" Padding="10,3" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding TrangThai, Converter={StaticResource TTText}}"
                                               Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Ghi Chú" Binding="{Binding MoTa}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
