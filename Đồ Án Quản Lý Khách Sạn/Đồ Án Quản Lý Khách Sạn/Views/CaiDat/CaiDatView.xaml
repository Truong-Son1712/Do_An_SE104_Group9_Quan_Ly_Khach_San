<UserControl x:Class="Đồ_Án_Quản_Lý_Khách_Sạn.Views.CaiDat.CaiDatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="720" HorizontalAlignment="Left">

            <TextBlock Style="{StaticResource H1}" Text="Tài Khoản" Margin="0,0,0,4"/>
            <TextBlock Style="{StaticResource Body}" Text="Thông tin tài khoản của bạn" Margin="0,0,0,24"/>

            <!-- Profile Card -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Avatar -->
                    <Border Grid.Column="0" Width="90" Height="90" CornerRadius="45"
                            Margin="0,0,28,0" VerticalAlignment="Top">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1565C0" Offset="0"/>
                                <GradientStop Color="#42A5F5" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="👤" FontSize="38"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Info -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding TenNhanVien}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,6"/>
                        <Border Background="#E3F2FD" CornerRadius="12" Padding="10,4"
                                HorizontalAlignment="Left" Margin="0,0,0,20">
                            <TextBlock Text="{Binding VaiTro}"
                                       Foreground="#1565C0" FontSize="12" FontWeight="SemiBold"/>
                        </Border>

                        <!-- 2×2 info fields -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Tài Khoản -->
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Tài Khoản" Style="{StaticResource Label}" Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding TaiKhoan}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>

                            <!-- Email -->
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="Email" Style="{StaticResource Label}" Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding Email}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>

                            <!-- Số Điện Thoại -->
                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="Số Điện Thoại" Style="{StaticResource Label}" Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding SDT}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>

                            <!-- Địa Chỉ -->
                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="Địa Chỉ" Style="{StaticResource Label}" Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding DiaChi}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Security Card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Bảo Mật" Style="{StaticResource H3}" Margin="0,0,0,16"/>

                    <Border Background="#FFF8F0" CornerRadius="10" Padding="16,14"
                            BorderBrush="#FFE0B2" BorderThickness="1">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource BtnWarning}"
                                    VerticalAlignment="Center" Command="{Binding DoiMatKhauCommand}"
                                    Margin="16,0,0,0" Height="32" Padding="12,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔑" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Đổi Mật Khẩu" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Mật Khẩu" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="Thay đổi mật khẩu định kỳ để bảo vệ tài khoản"
                                           Style="{StaticResource Body}" FontSize="12"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
