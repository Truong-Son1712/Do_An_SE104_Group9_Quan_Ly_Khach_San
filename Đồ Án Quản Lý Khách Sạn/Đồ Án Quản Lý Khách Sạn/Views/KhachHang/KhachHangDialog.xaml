<Window x:Class="Đồ_Án_Quản_Lý_Khách_Sạn.Views.KhachHang.KhachHangDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông Tin Khách Hàng" Height="560" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">

    <Border CornerRadius="12" ClipToBounds="True" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="12,12,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1565C0" Offset="0"/>
                        <GradientStop Color="#1E88E5" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,0,8,0">
                    <TextBlock x:Name="TxtTitle" Text="Thêm Khách Hàng"
                               Foreground="White" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Button Style="{StaticResource BtnClose}" Content="✕"
                            Click="BtnCancel_Click" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" Margin="24,16">
                <StackPanel>
                    <StackPanel>
                        <TextBlock Text="Họ và Tên *" Style="{StaticResource Label}"/>
                        <TextBox x:Name="TxtHoTen"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CMND/CCCD *" Style="{StaticResource Label}"/>
                            <TextBox x:Name="TxtCMND"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Giới Tính" Style="{StaticResource Label}"/>
                            <ComboBox x:Name="CboGioiTinh">
                                <ComboBoxItem Content="Nam" Tag="Nam" IsSelected="True"/>
                                <ComboBoxItem Content="Nữ"  Tag="Nu"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Số Điện Thoại" Style="{StaticResource Label}"/>
                            <TextBox x:Name="TxtSDT"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Ngày Sinh" Style="{StaticResource Label}"/>
                            <DatePicker x:Name="DpNgaySinh"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel>
                        <TextBlock Text="Email" Style="{StaticResource Label}"/>
                        <TextBox x:Name="TxtEmail"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Quốc Tịch" Style="{StaticResource Label}"/>
                            <TextBox x:Name="TxtQuocTich" Text="Việt Nam"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Loại Khách" Style="{StaticResource Label}"/>
                            <ComboBox x:Name="CboLoaiKhach">
                                <ComboBoxItem Content="Nội Địa"    Tag="NoiDia"    IsSelected="True"/>
                                <ComboBoxItem Content="Nước Ngoài" Tag="NuocNgoai"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel>
                        <TextBlock Text="Địa Chỉ" Style="{StaticResource Label}"/>
                        <TextBox x:Name="TxtDiaChi" Height="60" AcceptsReturn="True"
                                 VerticalContentAlignment="Top" Padding="10,8" TextWrapping="Wrap"/>
                    </StackPanel>

                    <Border x:Name="PnlError" Background="#FFEBEE" CornerRadius="6"
                            Padding="12,8" Visibility="Collapsed">
                        <TextBlock x:Name="TxtError" Foreground="#C62828" FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#F8FAFD" BorderBrush="#E0E0E0"
                    BorderThickness="0,1,0,0" CornerRadius="0,0,12,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Margin="24,0" VerticalAlignment="Center">
                    <Button Content="Hủy" Style="{StaticResource BtnOutline}" Width="90" Click="BtnCancel_Click" Margin="0,0,8,0"/>
                    <Button Content="💾  Lưu" Style="{StaticResource BtnPrimary}" Width="110" Click="BtnSave_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
