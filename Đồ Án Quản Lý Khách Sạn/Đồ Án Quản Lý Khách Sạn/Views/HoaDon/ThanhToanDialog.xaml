<Window x:Class="Đồ_Án_Quản_Lý_Khách_Sạn.Views.HoaDon.ThanhToanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thanh Toán Hóa Đơn" Height="500" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">

    <Border CornerRadius="12" ClipToBounds="True" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#2E7D32" Offset="0"/>
                        <GradientStop Color="#43A047" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,0,8,0">
                    <TextBlock Text="💳  Thanh Toán Hóa Đơn"
                               Foreground="White" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Button Style="{StaticResource BtnClose}" Content="✕" Foreground="#A5D6A7"
                            Click="BtnCancel_Click" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" Margin="24,16">
                <StackPanel>

                    <!-- Thông tin hóa đơn -->
                    <Border Background="#E3F2FD" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="THÔNG TIN HÓA ĐƠN" FontSize="10" FontWeight="Bold"
                                       Foreground="#1565C0" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtMaHD" FontSize="12" Foreground="#546E7A"/>
                            <TextBlock x:Name="TxtKhachHang" FontWeight="SemiBold" FontSize="14"
                                       Foreground="#1A237E" Margin="0,2,0,2"/>
                            <TextBlock x:Name="TxtPhong" Foreground="#546E7A" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- Chi tiết số tiền -->
                    <Border Background="#F5F7FA" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="CHI TIẾT THANH TOÁN" FontSize="10" FontWeight="Bold"
                                       Foreground="#546E7A" Margin="0,0,0,12"/>

                            <!-- Tiền phòng -->
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock x:Name="TxtTienPhong" DockPanel.Dock="Right"
                                           FontSize="14" Foreground="#37474F" FontWeight="SemiBold"/>
                                <TextBlock Text="Tiền phòng:" FontSize="13" Foreground="#546E7A"/>
                            </DockPanel>

                            <!-- Tiền cọc -->
                            <DockPanel Margin="0,0,0,8" x:Name="RowTienCoc">
                                <TextBlock x:Name="TxtTienCoc" DockPanel.Dock="Right"
                                           FontSize="14" Foreground="#E53935" FontWeight="SemiBold"/>
                                <TextBlock Text="Trừ tiền cọc (đã thu trước):" FontSize="13" Foreground="#546E7A"/>
                            </DockPanel>

                            <Rectangle Height="1.5" Fill="#DDEEFF" Margin="0,4,0,12"/>

                            <!-- Số tiền cần thanh toán -->
                            <DockPanel>
                                <TextBlock x:Name="TxtConLai" DockPanel.Dock="Right"
                                           FontSize="26" FontWeight="Bold" Foreground="#1B5E20"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="SỐ TIỀN CẦN THANH TOÁN" FontWeight="Bold"
                                               FontSize="11" Foreground="#2E7D32"/>
                                </StackPanel>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Phương thức thanh toán -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Phương Thức Thanh Toán" Style="{StaticResource Label}"/>
                        <ComboBox x:Name="CboPhuongThuc">
                            <ComboBoxItem Content="Tiền Mặt"      Tag="TienMat"     IsSelected="True"/>
                            <ComboBoxItem Content="Chuyển Khoản"  Tag="ChuyenKhoan"/>
                            <ComboBoxItem Content="Thẻ Ngân Hàng" Tag="The"/>
                        </ComboBox>
                    </StackPanel>

                    <Border x:Name="PnlError" Background="#FFEBEE" CornerRadius="6"
                            Padding="12,8" Visibility="Collapsed">
                        <TextBlock x:Name="TxtError" Foreground="#C62828" FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F8FAFD" BorderBrush="#E0E0E0"
                    BorderThickness="0,1,0,0" CornerRadius="0,0,12,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Margin="24,0" VerticalAlignment="Center">
                    <Button Content="Hủy" Style="{StaticResource BtnOutline}" Width="90"
                            Click="BtnCancel_Click" Margin="0,0,8,0"/>
                    <Button Content="✔  Xác Nhận Thanh Toán" Style="{StaticResource BtnSuccess}"
                            Width="190" Click="BtnConfirm_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
