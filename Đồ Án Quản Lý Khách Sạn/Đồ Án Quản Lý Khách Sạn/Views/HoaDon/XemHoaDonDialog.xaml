<Window x:Class="Đồ_Án_Quản_Lý_Khách_Sạn.Views.HoaDon.XemHoaDonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chi Tiết Hóa Đơn" Height="640" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">

    <Border CornerRadius="12" ClipToBounds="True" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1565C0" Offset="0"/>
                        <GradientStop Color="#1E88E5" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🧾" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TxtTitle" Text="Hóa Đơn #"
                                   Foreground="White" FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Style="{StaticResource BtnClose}" Content="✕"
                            Click="BtnClose_Click" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20,24,8">

                    <!-- Hotel Branding -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,18">
                        <Border Width="54" Height="54" CornerRadius="27"
                                HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1565C0" Offset="0"/>
                                    <GradientStop Color="#1E88E5" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🏨" FontSize="28"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="GRAND HOTEL" FontSize="16" FontWeight="Bold"
                                   Foreground="#1A237E" HorizontalAlignment="Center"/>
                        <TextBlock Text="Hóa Đơn Thanh Toán" FontSize="11"
                                   Foreground="#90A4AE" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="#E3F2FD" Margin="0,0,0,18"/>

                    <!-- Info Cards -->
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>

                        <!-- Customer / Room -->
                        <Border Grid.Column="0" Background="#F5F7FA" CornerRadius="10" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="KHÁCH HÀNG" FontSize="9" FontWeight="Bold"
                                           Foreground="#90A4AE" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                                    <TextBlock Text="👤" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="TxtKhach" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#1A237E" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                                    <TextBlock Text="🛏" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="TxtPhong" FontSize="12" Foreground="#546E7A"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Margin="0,2,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="📥" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Nhận phòng: " FontSize="11" Foreground="#90A4AE" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtNgayNhan" FontSize="11" FontWeight="SemiBold" Foreground="#37474F"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📤" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Trả phòng:   " FontSize="11" Foreground="#90A4AE" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtNgayTra" FontSize="11" FontWeight="SemiBold" Foreground="#37474F"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Invoice Meta -->
                        <Border Grid.Column="2" Background="#F5F7FA" CornerRadius="10" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="HÓA ĐƠN" FontSize="9" FontWeight="Bold"
                                           Foreground="#90A4AE" Margin="0,0,0,10"/>
                                <TextBlock Text="Thanh toán lúc:" FontSize="10" Foreground="#90A4AE" Margin="0,0,0,2"/>
                                <TextBlock x:Name="TxtNgayLap" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#1A237E" Margin="0,0,0,6"/>
                                <TextBlock x:Name="TxtNhanVien" FontSize="12"
                                           Foreground="#546E7A" Margin="0,0,0,10"/>
                                <Border CornerRadius="12" Background="#E3F2FD" Padding="10,4"
                                        HorizontalAlignment="Left" Margin="0,0,0,6">
                                    <TextBlock x:Name="TxtPhuongThuc" FontSize="11"
                                               FontWeight="SemiBold" Foreground="#1565C0"/>
                                </Border>
                                <Border x:Name="BorderTrangThai" CornerRadius="12" Padding="10,4"
                                        HorizontalAlignment="Left">
                                    <TextBlock x:Name="TxtTrangThai" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Summary -->
                    <Border Background="#F5F7FA" CornerRadius="10" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="CHI TIẾT THANH TOÁN" FontSize="9" FontWeight="Bold"
                                       Foreground="#90A4AE" Margin="0,0,0,12"/>

                            <!-- Tiền cọc -->
                            <DockPanel Margin="0,0,0,10" x:Name="RowCoc">
                                <TextBlock x:Name="TxtTienCoc" DockPanel.Dock="Right"
                                           FontSize="13" Foreground="#1565C0" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Tiền cọc (đặt phòng)" Foreground="#78909C" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </DockPanel>

                            <!-- Thanh toán trả phòng -->
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock x:Name="TxtThanhToanTraPhong" DockPanel.Dock="Right"
                                           FontSize="13" Foreground="#37474F" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Thanh toán lúc trả phòng" Foreground="#78909C" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </DockPanel>

                            <Rectangle Height="1.5" Fill="#DDEEFF" Margin="0,0,0,12"/>

                            <!-- Tổng -->
                            <DockPanel>
                                <TextBlock x:Name="TxtTong" DockPanel.Dock="Right"
                                           FontSize="24" FontWeight="Bold" Foreground="#2E7D32"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="TỔNG CỘNG" FontWeight="Bold" FontSize="14"
                                           Foreground="#546E7A" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F8FAFD" BorderBrush="#E0E0E0"
                    BorderThickness="0,1,0,0" CornerRadius="0,0,12,12">
                <Button Content="Đóng" Style="{StaticResource BtnOutline}"
                        Width="100" HorizontalAlignment="Right" Margin="24,0"
                        Click="BtnClose_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>
