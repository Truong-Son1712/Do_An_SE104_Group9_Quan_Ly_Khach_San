<Window x:Class="Đồ_Án_Quản_Lý_Khách_Sạn.Views.DatPhong.ChiTietDatPhongDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chi Tiết Đặt Phòng" Height="700" Width="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">

    <Border CornerRadius="12" ClipToBounds="True" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1565C0" Offset="0"/>
                        <GradientStop Color="#1E88E5" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,0,8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📋" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TxtTitle" Text="Chi Tiết Đặt Phòng"
                                   Foreground="White" FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Style="{StaticResource BtnClose}" Content="✕"
                            Click="BtnClose_Click" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,16,20,8">
                <StackPanel>

                    <!-- Booking Info -->
                    <Border Background="#E3F2FD" CornerRadius="8" Padding="16,14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="THÔNG TIN ĐẶT PHÒNG" FontSize="10" FontWeight="Bold"
                                       Foreground="#1565C0" Margin="0,0,0,12"/>

                            <Grid Margin="0,0,0,7">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="185"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBlock Text="Mã đặt phòng:" Foreground="#546E7A" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtMaDP" Grid.Column="1" Foreground="#1A237E" FontSize="12" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,0,0,7">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="185"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBlock Text="Phòng:" Foreground="#546E7A" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtPhong" Grid.Column="1" Foreground="#37474F" FontSize="12" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,0,0,7">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="185"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBlock Text="Thời điểm đặt phòng:" Foreground="#546E7A" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtNgayDat" Grid.Column="1" Foreground="#37474F" FontSize="12" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,0,0,7">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="185"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBlock x:Name="LblNhanPhong" Text="Nhận phòng:" Foreground="#546E7A" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtNgayNhan" Grid.Column="1" Foreground="#37474F" FontSize="12" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,0,0,7">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="185"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBlock x:Name="LblTraPhong" Text="Trả phòng:" Foreground="#546E7A" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtNgayTra" Grid.Column="1" Foreground="#37474F" FontSize="12" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,0,0,7">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="185"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBlock Text="Trạng thái:" Foreground="#546E7A" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtTrangThai" Grid.Column="1" Foreground="#37474F" FontSize="12" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid Margin="0,0,0,7">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="185"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBlock Text="Tiền cọc:" Foreground="#546E7A" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtTienCoc" Grid.Column="1" Foreground="#1565C0" FontSize="12" FontWeight="SemiBold"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="185"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <TextBlock Text="Ghi chú:" Foreground="#546E7A" FontSize="12" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                <TextBlock x:Name="TxtGhiChu" Grid.Column="1" Foreground="#37474F" FontSize="12" TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Customer List -->
                    <TextBlock Text="DANH SÁCH KHÁCH" FontSize="10" FontWeight="Bold"
                               Foreground="#546E7A" Margin="0,0,0,8"/>

                    <ItemsControl x:Name="IcKhachHang">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F5F7FA" CornerRadius="8" Padding="14,12" Margin="0,0,0,10"
                                        BorderBrush="#E0E0E0" BorderThickness="1">
                                    <StackPanel>
                                        <!-- Customer header -->
                                        <Border Background="#1565C0" CornerRadius="4" Padding="10,5" Margin="0,0,0,12">
                                            <TextBlock Text="{Binding TieuDe}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="White"/>
                                        </Border>

                                        <!-- 2-column info grid -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Left -->
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Margin="0,0,0,8">
                                                    <TextBlock Text="Mã khách hàng" FontSize="10" Foreground="#90A4AE"/>
                                                    <TextBlock Text="{Binding MaKH}" FontSize="12" Foreground="#1A237E" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,0,8">
                                                    <TextBlock Text="CMND / CCCD" FontSize="10" Foreground="#90A4AE"/>
                                                    <TextBlock Text="{Binding CMND}" FontSize="12" Foreground="#37474F" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,0,8">
                                                    <TextBlock Text="Giới tính" FontSize="10" Foreground="#90A4AE"/>
                                                    <TextBlock Text="{Binding GioiTinh}" FontSize="12" Foreground="#37474F" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,0,8">
                                                    <TextBlock Text="Ngày sinh" FontSize="10" Foreground="#90A4AE"/>
                                                    <TextBlock Text="{Binding NgaySinh}" FontSize="12" Foreground="#37474F" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Right -->
                                            <StackPanel Grid.Column="2">
                                                <StackPanel Margin="0,0,0,8">
                                                    <TextBlock Text="Số điện thoại" FontSize="10" Foreground="#90A4AE"/>
                                                    <TextBlock Text="{Binding SDT}" FontSize="12" Foreground="#37474F" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,0,8">
                                                    <TextBlock Text="Quốc tịch" FontSize="10" Foreground="#90A4AE"/>
                                                    <TextBlock Text="{Binding QuocTich}" FontSize="12" Foreground="#37474F" FontWeight="SemiBold"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,0,8">
                                                    <TextBlock Text="Loại khách" FontSize="10" Foreground="#90A4AE"/>
                                                    <TextBlock Text="{Binding LoaiKhach}" FontSize="12" Foreground="#37474F" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Full-width address -->
                                        <StackPanel>
                                            <TextBlock Text="Địa chỉ" FontSize="10" Foreground="#90A4AE"/>
                                            <TextBlock Text="{Binding DiaChi}" FontSize="12" Foreground="#37474F"
                                                       FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F8FAFD" BorderBrush="#E0E0E0"
                    BorderThickness="0,1,0,0" CornerRadius="0,0,12,12">
                <Button Content="Đóng" Style="{StaticResource BtnOutline}"
                        Width="100" HorizontalAlignment="Right" Margin="24,0"
                        Click="BtnClose_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>
