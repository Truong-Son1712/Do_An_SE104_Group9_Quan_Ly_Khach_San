<UserControl x:Class="Đồ_Án_Quản_Lý_Khách_Sạn.Views.DatPhong.DatPhongView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Đồ_Án_Quản_Lý_Khách_Sạn.Helpers"
             Background="{StaticResource BgBrush}">
    <UserControl.Resources>
        <conv:TrangThaiDatPhongTextConverter  x:Key="TTText"/>
        <conv:TrangThaiDatPhongColorConverter x:Key="TTColor"/>
        <conv:CurrencyConverter               x:Key="Currency"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource BtnPrimary}" Command="{Binding ThemCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Tạo Đặt Phòng" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource BtnInfo}" Command="{Binding SuaCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✎" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Chỉnh Sửa" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource BtnSuccess}" Command="{Binding NhanPhongCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✔" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Nhận Phòng" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource BtnWarning}" Command="{Binding TraPhongCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↩" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Trả Phòng" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource BtnDanger}" Command="{Binding HuyCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✕" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Hủy" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource BtnOutline}" Command="{Binding XemChiTietCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Chi Tiết" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel>
                <TextBlock Style="{StaticResource H1}" Text="Đặt Phòng"/>
                <TextBlock Style="{StaticResource Body}" Text="Quản lý đặt phòng, nhận phòng và trả phòng"/>
            </StackPanel>
        </DockPanel>

        <!-- Filter -->
        <Border Grid.Row="1" Style="{StaticResource CardSmall}" Margin="0,0,0,16">
            <WrapPanel>
                <StackPanel Width="220" Margin="0,0,16,0">
                    <TextBlock Text="Tìm kiếm" Style="{StaticResource Label}"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Tên khách, số phòng…"/>
                </StackPanel>
                <StackPanel Width="150" Margin="0,0,16,0">
                    <TextBlock Text="Trạng thái" Style="{StaticResource Label}"/>
                    <ComboBox SelectedValue="{Binding FilterTrangThai}" SelectedValuePath="Tag">
                        <ComboBoxItem Content="Tất cả"         Tag="TatCa" IsSelected="True"/>
                        <ComboBoxItem Content="Đã Đặt"         Tag="DaDat"/>
                        <ComboBoxItem Content="Đã Nhận Phòng"  Tag="DaNhanPhong"/>
                        <ComboBoxItem Content="Đã Trả Phòng"   Tag="DaTraPhong"/>
                        <ComboBoxItem Content="Đã Hủy"         Tag="HuyDat"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Width="140" Margin="0,0,16,0">
                    <TextBlock Text="Từ ngày" Style="{StaticResource Label}"/>
                    <DatePicker SelectedDate="{Binding TuNgay, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Width="140">
                    <TextBlock Text="Đến ngày" Style="{StaticResource Label}"/>
                    <DatePicker SelectedDate="{Binding DenNgay, Mode=TwoWay}"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding DatPhongs}" SelectedItem="{Binding Selected}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã ĐP"    Binding="{Binding MaDatPhong}"           Width="70"/>
                    <DataGridTextColumn Header="Khách Hàng" Binding="{Binding DanhSachKhachText}"   Width="*"/>
                    <DataGridTextColumn Header="Phòng"    Binding="{Binding Phong.SoPhong}"         Width="80"/>
                    <DataGridTextColumn Header="Loại"     Binding="{Binding Phong.LoaiPhong.TenLoaiPhong}" Width="*"/>
                    <DataGridTextColumn Header="Nhận Phòng" Binding="{Binding NgayNhanPhong, StringFormat=dd/MM/yyyy}" Width="110"/>
                    <DataGridTextColumn Header="Trả Phòng"  Binding="{Binding NgayTraPhong,  StringFormat=dd/MM/yyyy}" Width="110"/>
                    <DataGridTemplateColumn Header="Trạng Thái" Width="150" SortMemberPath="TrangThai">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding TrangThai, Converter={StaticResource TTColor}}"
                                        CornerRadius="12" Padding="10,3" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding TrangThai, Converter={StaticResource TTText}}"
                                               Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Ghi Chú" Binding="{Binding GhiChu}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
