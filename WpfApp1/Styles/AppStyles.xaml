<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Màu sắc cơ bản -->
    <SolidColorBrush x:Key="SidebarBackground" Color="#1E2254"/> <!-- Xanh đậm cực sang -->
    <SolidColorBrush x:Key="SidebarHover" Color="#2A2F72"/>
    <SolidColorBrush x:Key="MainBackground" Color="#F4F6F9"/>
    <SolidColorBrush x:Key="CardBlue" Color="#1A8FE3"/>
    <SolidColorBrush x:Key="CardGreen" Color="#3DA746"/>
    <SolidColorBrush x:Key="CardRed" Color="#E53935"/>
    <SolidColorBrush x:Key="CardOrange" Color="#FF8A00"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#1E293B"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#64748B"/>

    <!-- Đổ bóng chuẩn -->
    <DropShadowEffect x:Key="CardShadow" Color="#000000" BlurRadius="15" Opacity="0.05" ShadowDepth="3" Direction="270"/>

    <!-- Style thẻ Card màu trắng -->
    <Style TargetType="Border" x:Key="ModernCard">
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Margin" Value="10"/>
    </Style>

    <!-- Global Style cho TextBlock -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI, Inter, Arial"/>
    </Style>

    <!-- Style cho nút Menu bên trái (Sidebar) -->
    <Style TargetType="Button" x:Key="SidebarButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#A0A5CA"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="Margin" Value="10,2"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hover Effect -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource SidebarHover}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <!-- Pressed Effect -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#3B82F6"/> <!-- Đổi màu nhấn xanh dương -->
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Nút trên TopBar -->
    <Style TargetType="Button" x:Key="TopBarButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#64748B"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Width" Value="35"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="#E2E8F0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Nút Đóng (TopBar Close) -->
    <Style TargetType="Button" BasedOn="{StaticResource TopBarButton}" x:Key="TopBarCloseButton">
        <Setter Property="Foreground" Value="#EF4444"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#EF4444"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
