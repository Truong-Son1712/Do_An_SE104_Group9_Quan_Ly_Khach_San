<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Khách Sạn"
        Height="650" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="#F4F6F9">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1F2937">
            <StackPanel>
                <TextBlock Text="KHÁCH SẠN"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="20,25,20,5"/>
                <TextBlock Text="Quản trị hệ thống"
                           Foreground="#9CA3AF"
                           FontSize="12"
                           Margin="20,0,20,20"/>

                <Border Background="#374151" Padding="15,12" Margin="10,0,10,15" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="{Binding UserFullName}"
                                   Foreground="White"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding UserRoleDisplay}"
                                   Foreground="#9CA3AF"
                                   FontSize="12"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>

                <Button Content="🏠 Quản lý Phòng"
                        Click="BtnPhong_Click"
                        Style="{StaticResource SidebarButton}"
                        Visibility="{Binding ShowNhanVien, Converter={StaticResource BoolToVis}}"/>

                <Button Content="📋 Phiếu Thuê"
                        Click="BtnBooking_Click"
                        Style="{StaticResource SidebarButton}"
                        Visibility="{Binding ShowNhanVien, Converter={StaticResource BoolToVis}}"/>

                <Button Content="💵 Hóa Đơn"
                        Click="BtnHoaDon_Click"
                        Style="{StaticResource SidebarButton}"
                        Visibility="{Binding ShowNhanVien, Converter={StaticResource BoolToVis}}"/>

                <Button Content="📊 Báo Cáo"
                        Click="BtnBaoCao_Click"
                        Style="{StaticResource SidebarButton}"
                        Visibility="{Binding ShowBaoCao, Converter={StaticResource BoolToVis}}"/>

                <Button Content="👥 Phân Quyền"
                        Click="BtnPhanQuyen_Click"
                        Style="{StaticResource SidebarButton}"
                        Visibility="{Binding ShowPhanQuyen, Converter={StaticResource BoolToVis}}"/>

                <Button Content="🚪 Đăng xuất"
                        Click="BtnLogout_Click"
                        Style="{StaticResource SidebarButton}"
                        Margin="10,30,10,5"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Name="TxtTitle"
                               Text="Trang chủ"
                               FontSize="20"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="25,0,0,0"/>
                    <Button Name="BtnClose"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Width="36" Height="36"
                            Margin="0,0,15,0"
                            Content="X"
                            FontWeight="Bold"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1"
                            Name="ContentArea"
                            Margin="15"/>
        </Grid>
    </Grid>
</Window>
