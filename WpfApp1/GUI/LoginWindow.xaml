<Window x:Class="WpfApp1.GUI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Khách Sạn - Đăng Nhập"
        Height="520" Width="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#F4F6F9">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="8" Background="White" Margin="0">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button Name="BtnClose"
                    Grid.Row="0"
                    HorizontalAlignment="Right"
                    Width="28" Height="28"
                    Content="X"
                    FontWeight="Bold"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnClose_Click"/>

            <TextBlock Grid.Row="1"
                       Text="ĐĂNG NHẬP"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#0078D7"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,30"/>

            <TextBlock Grid.Row="2" Text="Tên đăng nhập" Margin="0,0,0,5" Foreground="#555"/>
            <TextBox Grid.Row="3"
                     Name="TxtUsername"
                     Height="36"
                     Padding="8,6"
                     FontSize="14"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="4" Text="Mật khẩu" Margin="0,15,0,5" Foreground="#555"/>
            <PasswordBox Grid.Row="5"
                         Name="PwdPassword"
                         Height="36"
                         Padding="8,6"
                         FontSize="14"
                         PasswordChanged="PwdPassword_PasswordChanged"/>

            <TextBlock Grid.Row="6"
                       Text="{Binding ErrorMessage}"
                       Foreground="Red"
                       Margin="0,10,0,0"
                       TextWrapping="Wrap"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>

            <Button Grid.Row="8"
                    Content="Đăng Nhập"
                    Height="42"
                    Margin="0,20,0,0"
                    Background="#0078D7"
                    Foreground="White"
                    FontSize="16"
                    FontWeight="Bold"
                    Cursor="Hand"
                    BorderThickness="0"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsNotLoading}"/>
        </Grid>
    </Border>
</Window>
