<UserControl x:Class="WpfApp1.GUI.InvoiceUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="QUẢN LÝ HÓA ĐƠN &amp; THANH TOÁN" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" Foreground="#1F2937"/>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <!-- TAB 1: CHỜ THANH TOÁN -->
            <TabItem Header="Chờ thanh toán" FontSize="14" Padding="15,5">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Width="250" Height="30" Padding="5,0" VerticalContentAlignment="Center"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 ToolTip="Nhập tên khách, mã phiếu hoặc phòng"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding PendingBookings}" SelectedItem="{Binding SelectedBooking}" 
                              AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                              Background="White" RowBackground="#F9F9F9" AlternatingRowBackground="White" 
                              BorderBrush="#DDDDDD" BorderThickness="1" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã Phiếu" Binding="{Binding BookingID}" Width="100"/>
                            <DataGridTextColumn Header="Phòng" Binding="{Binding RoomNumber}" Width="80"/>
                            <DataGridTextColumn Header="Khách đại diện" Binding="{Binding BookerName}" Width="*"/>
                            <DataGridTextColumn Header="Ngày nhận" Binding="{Binding CheckInDate, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                            <DataGridTextColumn Header="Số khách" Binding="{Binding NumberOfGuests}" Width="80"/>
                            <DataGridTextColumn Header="Giá phòng (ngày)" Binding="{Binding PricePerDay, StringFormat={}{0:N0} VNĐ}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Tải lại" Command="{Binding LoadDataCommand}" Width="100" Height="35" Margin="0,0,10,0"
                                Background="#6C757D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <Button Content="Thanh Toán" Command="{Binding CheckoutCommand}" Width="120" Height="35"
                                Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- TAB 2: LỊCH SỬ HÓA ĐƠN -->
            <TabItem Header="Lịch sử hóa đơn" FontSize="14" Padding="15,5">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0" ItemsSource="{Binding InvoiceHistory}" 
                              AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                              Background="White" RowBackground="#F9F9F9" AlternatingRowBackground="White" 
                              BorderBrush="#DDDDDD" BorderThickness="1" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã Hóa Đơn" Binding="{Binding InvoiceID}" Width="150"/>
                            <DataGridTextColumn Header="Phòng" Binding="{Binding RoomNumber}" Width="80"/>
                            <DataGridTextColumn Header="Khách hàng" Binding="{Binding BookerName}" Width="*"/>
                            <DataGridTextColumn Header="Ngày xuất" Binding="{Binding IssuedDate, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                            <DataGridTextColumn Header="Hình thức" Binding="{Binding PaymentMethod}" Width="100"/>
                            <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TotalAmount, StringFormat={}{0:N0} VNĐ}" Width="150" Foreground="Red" FontWeight="Bold"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="1" Content="Làm mới lịch sử" Command="{Binding LoadDataCommand}" Width="120" Height="35" Margin="0,15,0,0"
                            HorizontalAlignment="Right" Background="#6C757D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
