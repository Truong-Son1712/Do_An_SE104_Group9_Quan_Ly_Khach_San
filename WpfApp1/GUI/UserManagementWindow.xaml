<Window x:Class="WpfApp1.GUI.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý tài khoản"
        Height="600" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Quản lý tài khoản người dùng"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <TabControl Grid.Row="1">

            <!-- Tab 1: Danh sách -->
            <TabItem Header="Danh sách tài khoản">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
                            Content="Tải lại"
                            Width="100" Height="32"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,8"
                            Command="{Binding LoadCommand}"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUser}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="32">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã TK"      Binding="{Binding AccountID}" Width="120"/>
                            <DataGridTextColumn Header="Tên đăng nhập" Binding="{Binding Username}" Width="160"/>
                            <DataGridTextColumn Header="Họ tên"     Binding="{Binding FullName}" Width="200"/>
                            <DataGridTextColumn Header="Vai trò"    Binding="{Binding RoleName}" Width="120"/>
                            <DataGridCheckBoxColumn Header="Hoạt động" Binding="{Binding IsActive}" Width="80"/>
                            <DataGridTextColumn Header="Lần đăng nhập gần nhất"
                                                Binding="{Binding LastLogin}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Tab 2: Tạo mới -->
            <TabItem Header="Tạo tài khoản">
                <StackPanel Margin="15" Width="400" HorizontalAlignment="Left">
                    <TextBlock Text="Tên đăng nhập" Margin="0,5,0,3"/>
                    <TextBox Height="32" Padding="6,4"
                             Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Mật khẩu" Margin="0,12,0,3"/>
                    <PasswordBox Height="32" Padding="6,4"
                                 PasswordChanged="PwdCreate_Changed"/>

                    <TextBlock Text="Nhân viên" Margin="0,12,0,3"/>
                    <ComboBox Height="32"
                              ItemsSource="{Binding AvailableStaff}"
                              DisplayMemberPath="FullName"
                              SelectedValuePath="StaffID"
                              SelectedValue="{Binding SelectedStaffId}"/>

                    <TextBlock Text="Vai trò" Margin="0,12,0,3"/>
                    <ComboBox Height="32"
                              ItemsSource="{Binding Roles}"
                              DisplayMemberPath="RoleName"
                              SelectedValuePath="RoleID"
                              SelectedValue="{Binding SelectedRoleId}"/>

                    <Button Content="Tạo tài khoản"
                            Height="38"
                            Margin="0,25,0,0"
                            Background="#0078D7"
                            Foreground="White"
                            FontWeight="Bold"
                            Command="{Binding CreateUserCommand}"/>
                </StackPanel>
            </TabItem>

            <!-- Tab 3: Chỉnh sửa -->
            <TabItem Header="Chỉnh sửa">
                <StackPanel Margin="15" Width="400" HorizontalAlignment="Left"
                            IsEnabled="{Binding HasSelectedUser}">
                    <TextBlock Text="Chọn tài khoản ở tab Danh sách trước khi chỉnh sửa."
                               Foreground="Gray" Margin="0,0,0,15"/>

                    <TextBlock Text="Tên đăng nhập" Margin="0,5,0,3"/>
                    <TextBox Height="32" Padding="6,4"
                             Text="{Binding EditUsername, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Vai trò" Margin="0,12,0,3"/>
                    <ComboBox Height="32"
                              ItemsSource="{Binding Roles}"
                              DisplayMemberPath="RoleName"
                              SelectedValuePath="RoleID"
                              SelectedValue="{Binding EditRoleId}"/>

                    <CheckBox Content="Tài khoản đang hoạt động"
                              Margin="0,15,0,0"
                              IsChecked="{Binding EditIsActive}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,25,0,0">
                        <Button Content="Lưu thay đổi"
                                Height="38" Width="140"
                                Background="#0078D7" Foreground="White" FontWeight="Bold"
                                Command="{Binding UpdateUserCommand}"/>
                        <Button Content="Vô hiệu hóa"
                                Height="38" Width="140"
                                Margin="10,0,0,0"
                                Background="#DC2626" Foreground="White" FontWeight="Bold"
                                Command="{Binding DeactivateUserCommand}"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Tab 4: Đổi mật khẩu -->
            <TabItem Header="Đổi mật khẩu">
                <StackPanel Margin="15" Width="400" HorizontalAlignment="Left"
                            IsEnabled="{Binding HasSelectedUser}">
                    <TextBlock Text="Mật khẩu hiện tại" Margin="0,5,0,3"/>
                    <PasswordBox Height="32" Padding="6,4"
                                 PasswordChanged="PwdCurrent_Changed"/>

                    <TextBlock Text="Mật khẩu mới" Margin="0,12,0,3"/>
                    <PasswordBox Height="32" Padding="6,4"
                                 PasswordChanged="PwdNew_Changed"/>

                    <TextBlock Text="Xác nhận mật khẩu" Margin="0,12,0,3"/>
                    <PasswordBox Height="32" Padding="6,4"
                                 PasswordChanged="PwdConfirm_Changed"/>

                    <Button Content="Đổi mật khẩu"
                            Height="38"
                            Margin="0,25,0,0"
                            Background="#0078D7"
                            Foreground="White"
                            FontWeight="Bold"
                            Command="{Binding ChangePasswordCommand}"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#F3F4F6" Margin="0,10,0,0" Padding="10,8">
            <TextBlock Text="{Binding Status}" Foreground="#374151"/>
        </Border>
    </Grid>
</Window>
